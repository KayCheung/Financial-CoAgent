# S1 Gateway dev auth. Replace with OIDC/SSO in production.
DEV_BEARER_TOKEN=dev-local-token
DEV_USER_ID=dev-user
DEV_USER_NAME=Local Developer
DEV_TENANT_ID=dev-tenant
DEV_ROLE=operator

# Comma-separated CORS origins. Optional.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
UPLOAD_DIR=./uploads
AUDIT_WAL_DIR=./audit_wal

# Database configuration priority:
# 1. DATABASE_URL if explicitly set
# 2. Nacos datasource config
# 3. Local sqlite fallback for development/tests
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:15432/financial_coagent_phase1

# Nacos datasource config source
NACOS_HOST=127.0.0.1
NACOS_PORT=8848
NACOS_USERNAME=dev
NACOS_PASSWORD=dev
NACOS_NAMESPACE=dev
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATASOURCE_DATA_ID=agent-datasource.yml

# Remote PaddleOCR service
REMOTE_OCR_URL=http://10.36.6.252:8100/ocr
REMOTE_OCR_TOKEN=
